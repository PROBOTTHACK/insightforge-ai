APP_NAME=InsightForge AI
ENVIRONMENT=production
FRONTEND_ORIGIN=https://insightforge-ai-self.vercel.app

# Optional. The MVP uses in-memory storage; wire these in Phase 2.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=datasets

# AI provider. Use "balanced", "gemini", "huggingface", or "local".
# Local is deterministic and needs no key.
AI_PROVIDER=balanced
# "balanced" alternates between Gemini and Hugging Face. "fallback" tries primary first.
AI_PROVIDER_STRATEGY=balanced

# Gemini API. Set AI_PROVIDER=gemini to use this.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Hugging Face Inference Providers. Set AI_PROVIDER=huggingface to use this.
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGINGFACE_PROVIDER=auto
